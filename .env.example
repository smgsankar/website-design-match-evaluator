# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# OpenAI / Vercel AI Gateway compatible endpoint
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional for AI Gateway / proxy endpoint
# OPENAI_BASE_URL=https://ai-gateway.vercel.sh/v1

# Upstash Redis (Vercel Marketplace)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local development override only.
# Allows capture of localhost/127.0.0.1/::1 URLs in compare API.
ALLOW_LOCALHOST_CAPTURE=false
