# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# OpenAI / Vercel AI Gateway compatible endpoint
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional for AI Gateway / proxy endpoint
# OPENAI_BASE_URL=https://ai-gateway.vercel.sh/v1

# Upstash Redis (Vercel Marketplace)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local development override only.
# Allows capture of localhost/127.0.0.1/::1 URLs in compare API.
ALLOW_LOCALHOST_CAPTURE=false

# Optional localhost capture scale factor (for HiDPI/@2x design exports).
# Example: set to 2 to capture localhost at half CSS viewport and up-scale to design dimensions.
# LOCALHOST_CAPTURE_SCALE_FACTOR=2
